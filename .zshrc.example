# If you come from bash you might have to change your $PATH.
# export PATH=$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set name of the theme to load
ZSH_THEME="emerald-zsh-theme"

# Plugins de Oh My Zsh (zsh-syntax-highlighting se carga al final)
plugins=(
    git
    zsh-autosuggestions
)

source $ZSH/oh-my-zsh.sh

# di=38;5;85;1 -> Carpetas en Verde Menta
# ln=38;5;44   -> Enlaces en Turquesa
# ex=38;5;42;1 -> Ejecutables en Verde Esmeralda

export LS_COLORS="di=38;5;85;1:ln=38;5;44:so=38;5;203:ex=38;5;42;1:bd=40;33;01:cd=40;33;01"

alias ls='ls --color=auto'

# Habilitar autocompletado (Tab) usando la paleta LS_COLORS
zmodload zsh/complist 2>/dev/null
autoload -Uz compinit && compinit
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}

export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=238"

source ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

typeset -A ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[command]='fg=42,bold'             # Comandos en Esmeralda (#00e6a6)
ZSH_HIGHLIGHT_STYLES[builtin]='fg=44,bold'             # Builtins en Turquesa (#00cec9)
ZSH_HIGHLIGHT_STYLES[alias]='fg=85,bold'               # Aliases en Menta (#73fbfd)
ZSH_HIGHLIGHT_STYLES[precommand]='fg=42,bold'          # sudo / time / doas
ZSH_HIGHLIGHT_STYLES[function]='fg=44,bold'             # Funciones
ZSH_HIGHLIGHT_STYLES[single-quoted-argument]='fg=204' # Strings en Rosa (#ff7675)
ZSH_HIGHLIGHT_STYLES[double-quoted-argument]='fg=204'
ZSH_HIGHLIGHT_STYLES[single-hyphen-option]='fg=221'      # Banderas -a en Dorado (#ffeaa7)
ZSH_HIGHLIGHT_STYLES[double-hyphen-option]='fg=221'      # Banderas --option en Dorado
ZSH_HIGHLIGHT_STYLES[path]='fg=85'                     # Rutas válidas en Menta
ZSH_HIGHLIGHT_STYLES[comment]='fg=238'                  # Comentarios en Gris tenue
ZSH_HIGHLIGHT_STYLES[unknown-token]='fg=203,bold'       # Comandos no encontrados/errores

REPORTTIME=3